{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "mode": { "type": "string", "enum": ["education", "business", "setup"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "User memory/context for AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["education", "business"] },
        "data": { "type": "object", "description": "Dynamic fields collected during onboarding" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mode", "data", "updatedAt"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation history with the AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["education", "business"] },
        "title": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mode", "messages", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles, indexed by uid"
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "Onboarding answers and context for the user"
    },
    "/users/{userId}/chatSessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Chat histories for the user"
    }
  }
}
